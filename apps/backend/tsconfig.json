{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    
    "module": "commonjs",
    "moduleResolution": "node",

    "ignoreDeprecations": "6.0",

    "rootDir": "src",
    "outDir": "dist",

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,

    "incremental": true,

    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,

    "forceConsistentCasingInFileNames": true,

    "sourceMap": true,

    "baseUrl": ".",

    "paths": {
      "@/*": ["src/*"]
    },

    "types": ["node"]
  },

  "include": ["src/**/*"],

  "exclude": [
    "node_modules",
    "dist"
  ]
}